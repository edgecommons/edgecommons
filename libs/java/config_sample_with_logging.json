{
  "logging": {
    "level": "INFO",
    "java_format": "%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n",
    "globalControl": true,
    "fileLogging": {
      "enabled": true,
      "filePath": "/var/log/{ComponentName}-{ThingName}.log"
    },
    "loggers": {
      "com.mbreissi.edgecommons": "DEBUG",
      "com.mbreissi.edgecommons.messaging": "TRACE",
      "org.apache.http": "WARN"
    }
  },
  "tags": {
    "Environment": "Development",
    "Application": "EdgeCommons",
    "Region": "us-west-2"
  },
  "heartbeat": {
    "intervalSecs": 60,
    "destination": "northbound"
  },
  "metricEmission": {
    "target": "cloudwatch",
    "namespace": "EdgeCommons/{Environment}",
    "dimensions": {
      "ThingName": "{ThingName}",
      "ComponentName": "{ComponentName}",
      "Application": "{Application}",
      "Region": "{Region}"
    }
  },
  "component": {
    "global": {
      "setting1": "value1",
      "setting2": "value2"
    },
    "instances": [
      {
        "id": "instance1",
        "config": {
          "param1": "instance1-value1",
          "param2": "instance1-value2"
        }
      },
      {
        "id": "instance2",
        "config": {
          "param1": "instance2-value1",
          "param2": "instance2-value2"
        }
      }
    ]
  }
}
