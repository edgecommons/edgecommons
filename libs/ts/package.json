{
  "name": "@edgecommons/ggcommons",
  "version": "0.1.1",
  "description": "GGCommons TypeScript library for AWS IoT Greengrass v2 components: configuration, messaging (GREENGRASS IPC + STANDALONE dual-MQTT), metrics, heartbeat, logging, credentials, parameters, and telemetry streaming — at parity with the Java/Python/Rust implementations.",
  "license": "Apache-2.0",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "aws-iot-device-sdk-v2": "^1.27.0",
    "mqtt": "^5"
  },
  "optionalDependencies": {
    "@mbreissi/ggstreamlog-node": "*",
    "@aws-sdk/client-kms": "^3.1073.0",
    "@aws-sdk/client-secrets-manager": "^3.1073.0",
    "@aws-sdk/client-ssm": "^3.1073.0",
    "graphene-pk11": "^2.3.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@aws-sdk/client-cloudwatch": "^3.1073.0",
    "@aws-sdk/client-kms": "^3.1073.0",
    "@aws-sdk/client-secrets-manager": "^3.1073.0",
    "@aws-sdk/client-ssm": "^3.1073.0",
    "@napi-rs/cli": "^3.7.2",
    "@types/node": "^20",
    "@vitest/coverage-v8": "^4.1.9",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
