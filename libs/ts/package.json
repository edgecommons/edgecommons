  },
  "optionalDependencies": {
    "@aws-sdk/client-kms": "^3.1073.0",
    "@aws-sdk/client-secrets-manager": "^3.1073.0",
    "graphene-pk11": "^2.3.0"
  },
  "devDependencies": {
    "@aws-sdk/client-cloudwatch": "^3.1073.0",
    "@aws-sdk/client-kms": "^3.1073.0",
    "@aws-sdk/client-secrets-manager": "^3.1073.0",
    "@napi-rs/cli": "^3.7.2",
    "@types/node": "^20",
    "@vitest/coverage-v8": "^4.1.9",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
