{
  "name": "@breissinger/ggstreamlog-node",
  "version": "0.1.0",
  "description": "napi-rs native addon for the ggcommons telemetry-streaming core.",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "Apache-2.0",
  "napi": {
    "binaryName": "ggstreamlog-node",
    "targets": [
      "x86_64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "aarch64-apple-darwin"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "*.node"
  ]
}
