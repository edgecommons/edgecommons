# npm workspace install output (root node_modules; per-package node_modules are
# ignored by their own .gitignore files). The committed root package-lock.json is
# the single lockfile for the JS/TS workspace.
node_modules/

# The root package-lock.json is the ONLY lockfile for the JS/TS workspace. Ignore stray
# per-package lockfiles (e.g. from a standalone `npm install` in a sub-directory), which npm
# workspaces don't use and which can silently pin unintended registry resolutions.
**/package-lock.json
!/package-lock.json

# Generated build output.
build/

# Local tool state.
.claude/

# Runtime credentials-vault artifacts written by components at run time (e.g. the
# example skeletons when run locally) — encrypted-at-rest, never committed.
.vault/
*.vault.key

# Local IoT device test certificates / private keys (used only for manual live
# STANDALONE MQTT testing against AWS IoT Core) — never commit real key material.
creds/
**/creds/
*.private.key
