{
  "logging": { "level": "DEBUG", "rust_format": "{timestamp} [{level}] {target} - {message}" },
  "heartbeat": {
    "enabled": true,
    "intervalSecs": 5,
    "measures": { "cpu": true, "memory": true },
    "destination": "local"
  },
  "metricEmission": { "target": "log", "namespace": "ggcommons" },
  "tags": { "site": "factory-1" },
  "component": {
    "global": { "publish_interval": 3 },
    "instances": [ { "id": "main" } ]
  }
}
