{
  "schemaVersion": 2,
  "id": "java/service",
  "language": "JAVA",
  "kind": "service",
  "description": "Java component built on the edgecommons Java library.",
  "platforms": [
    "GREENGRASS",
    "HOST",
    "KUBERNETES"
  ],
  "substitutions": {
    "compose.yaml": [
      "BINNAME",
      "COMPONENTNAME",
      "JARNAME"
    ],
    "config.schema.json": [
      "COMPONENTNAME"
    ],
    "Dockerfile": [
      "JARNAME"
    ],
    "gdk-config.json": [
      "AUTHOR",
      "BUCKET",
      "COMPONENTFULLNAME",
      "REGION"
    ],
    "pom.xml": [
      "COMPONENTNAME",
      "EDGECOMMONS_VERSION",
      "JARNAME",
      "MAINCLASSNAME",
      "PACKAGE"
    ],
    "README.md": [
      "COMPONENTFULLNAME",
      "COMPONENTNAME",
      "JARNAME"
    ],
    "recipe.yaml": [
      "AUTHOR",
      "COMPONENTFULLNAME",
      "DESCRIPTION",
      "JARNAME",
      "MAINCLASSNAME"
    ],
    "k8s/configmap.yaml": [
      "COMPONENTNAME"
    ],
    "k8s/deployment.yaml": [
      "COMPONENTNAME"
    ],
    "src/main/java/com/mbreissi/testcomponent/App.java": [
      "COMPONENTFULLNAME",
      "COMPONENTNAME",
      "PACKAGE"
    ],
    "supervisor/component.conf": [
      "BINNAME",
      "COMPONENTNAME",
      "JARNAME"
    ],
    "test-configs/standalone-messaging.json": [
      "COMPONENTNAME"
    ]
  },
  "packs": {
    "GREENGRASS": [
      "recipe.yaml",
      "gdk-config.json"
    ],
    "HOST": [
      "compose.yaml",
      "supervisor",
      "Dockerfile"
    ],
    "KUBERNETES": [
      "Dockerfile",
      "k8s"
    ]
  },
  "conditional": [],
  "renames": [
    {
      "from": "src/main/java/com/mbreissi/testcomponent",
      "to": "src/main/java/{PACKAGEPATH}"
    },
    {
      "from": "src/main/java/{PACKAGEPATH}/App.java",
      "to": "src/main/java/{PACKAGEPATH}/{COMPONENTNAME}.java"
    },
    {
      "from": "test-configs/TestComponent.json",
      "to": "test-configs/{COMPONENTNAME}.json"
    }
  ]
}
