{
  "language": "JAVA",
  "description": "Java Greengrass component built on the ggcommons Java library.",
  "substitutions": {
    "recipe.yaml": ["DESCRIPTION", "COMPONENTFULLNAME", "AUTHOR", "JARNAME", "MAINCLASSNAME"],
    "gdk-config.json": ["COMPONENTFULLNAME", "AUTHOR", "BUCKET", "REGION"],
    "pom.xml": ["PACKAGE", "JARNAME", "COMPONENTNAME"],
    "src/main/java/com/breissinger/testcomponent/App.java": ["PACKAGE", "COMPONENTNAME", "COMPONENTFULLNAME"],
    "README.md": ["COMPONENTNAME", "COMPONENTFULLNAME", "JARNAME"]
  },
  "renames": [
    {"from": "src/main/java/com/breissinger/testcomponent", "to": "src/main/java/{PACKAGEPATH}"},
    {"from": "src/main/java/{PACKAGEPATH}/App.java", "to": "src/main/java/{PACKAGEPATH}/{COMPONENTNAME}.java"},
    {"from": "test-configs/TestComponent.json", "to": "test-configs/{COMPONENTNAME}.json"}
  ]
}
