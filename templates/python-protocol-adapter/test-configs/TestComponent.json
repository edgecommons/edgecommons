  "component": {
    "global": { "defaults": { "pollIntervalMs": 1000 } },
    "instances": [
      {
        "id": "device1",
        "adapter": "example",
        "connection": { "_comment": "TODO: your protocol endpoint, e.g. host/port/unitId or an OPC UA endpoint" },
