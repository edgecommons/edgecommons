{
  "hierarchy": { "levels": ["site", "device"] },
  "identity": { "site": "site1" },
  "tags": { "appId": "dev" },
  "logging": { "level": "INFO" },
  "metricEmission": { "target": "messaging", "targetConfig": { "destination": "local" } },
  "component": {
    "global": {
      "defaults": { "pollIntervalMs": 5000 },
      "healthThresholds": { "staleSignalSecs": 30 }
    },
    "instances": [
      {
        "id": "device-1",
        "adapter": "sim",
        "connection": { "endpoint": "sim://device-1" },
        "pollIntervalMs": 5000,
        "writes": { "allow": [] }
      }
    ]
  }
}
