{
  "schemaVersion": 2,
  "id": "rust/processor",
  "language": "RUST",
  "kind": "processor",
  "description": "Rust processing component: subscribe, transform through a pipeline of stages, forward.",
  "platforms": [
    "GREENGRASS",
    "HOST",
    "KUBERNETES"
  ],
  "requires": [
    "EDGECOMMONS_DEP"
  ],
  "substitutions": {
    ".cargo/config.toml": [
      "LIBRARY_LOCAL_PATH"
    ],
    "build.sh": [
      "BINNAME",
      "COMPONENTFULLNAME"
    ],
    "Cargo.toml": [
      "BINNAME",
      "DESCRIPTION",
      "EDGECOMMONS_DEP",
      "LICENSE"
    ],
    "compose.yaml": [
      "BINNAME",
      "COMPONENTNAME"
    ],
    "config.schema.json": [
      "COMPONENTNAME"
    ],
    "Dockerfile": [
      "BINNAME"
    ],
    "gdk-config.json": [
      "AUTHOR",
      "BUCKET",
      "COMPONENTFULLNAME",
      "REGION"
    ],
    "README.md": [
      "BINNAME",
      "COMPONENTNAME"
    ],
    "recipe.yaml": [
      "AUTHOR",
      "BINNAME",
      "COMPONENTFULLNAME",
      "DESCRIPTION"
    ],
    "k8s/configmap.yaml": [
      "BINNAME"
    ],
    "k8s/deployment.yaml": [
      "BINNAME"
    ],
    "src/app.rs": [
      "BINNAME",
      "COMPONENTNAME"
    ],
    "src/main.rs": [
      "COMPONENTFULLNAME",
      "COMPONENTNAME"
    ],
    "supervisor/component.conf": [
      "BINNAME",
      "COMPONENTNAME"
    ],
    "test-configs/config.json": [
      "BINNAME"
    ],
    "test-configs/standalone-messaging.json": [
      "BINNAME"
    ],
    "AGENTS.md": [
      "BINNAME",
      "COMPONENTFULLNAME",
      "COMPONENTNAME"
    ],
    "CLAUDE.md": [
      "COMPONENTFULLNAME",
      "COMPONENTNAME"
    ],
    "DESIGN.md": [
      "COMPONENTFULLNAME",
      "COMPONENTNAME"
    ],
    "docs/README.md": [
      "COMPONENTFULLNAME",
      "COMPONENTNAME"
    ],
    "docs/tutorial.md": [
      "BINNAME",
      "COMPONENTFULLNAME"
    ],
    "docs/how-to-guides.md": [
      "BINNAME"
    ],
    "docs/sample-configurations.md": [
      "BINNAME"
    ],
    "docs/reference/configuration.md": [
      "BINNAME",
      "COMPONENTNAME"
    ],
    "docs/reference/messaging-interface.md": [
      "BINNAME"
    ],
    "docs/reference/metrics.md": [
      "BINNAME",
      "COMPONENTNAME"
    ]
  },
  "renames": [],
  "packs": {
    "GREENGRASS": [
      "recipe.yaml",
      "gdk-config.json",
      "build.sh"
    ],
    "HOST": [
      "compose.yaml",
      "supervisor",
      "Dockerfile"
    ],
    "KUBERNETES": [
      "Dockerfile",
      "k8s"
    ]
  },
  "conditional": [
    {
      "when": "dep:pinned-rev",
      "paths": [
        ".cargo"
      ]
    }
  ]
}
