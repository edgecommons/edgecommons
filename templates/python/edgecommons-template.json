{
  "schemaVersion": 2,
  "id": "python/service",
  "language": "PYTHON",
  "kind": "service",
  "description": "Python component built on the edgecommons Python library.",
  "platforms": [
    "GREENGRASS",
    "HOST",
    "KUBERNETES"
  ],
  "requires": [
    "EDGECOMMONS_DEP"
  ],
  "substitutions": {
    "compose.yaml": [
      "BINNAME",
      "COMPONENTNAME"
    ],
    "config.schema.json": [
      "COMPONENTNAME"
    ],
    "Dockerfile": [
      "COMPONENTNAME"
    ],
    "gdk-config.json": [
      "AUTHOR",
      "BUCKET",
      "COMPONENTFULLNAME",
      "REGION"
    ],
    "main.py": [
      "COMPONENTNAME"
    ],
    "README.md": [
      "COMPONENTFULLNAME",
      "COMPONENTNAME"
    ],
    "recipe.yaml": [
      "AUTHOR",
      "COMPONENTFULLNAME",
      "COMPONENTNAME",
      "DESCRIPTION"
    ],
    "requirements.txt": [
      "EDGECOMMONS_DEP"
    ],
    "app/greengrass_app.py": [
      "COMPONENTNAME"
    ],
    "k8s/configmap.yaml": [
      "COMPONENTNAME"
    ],
    "k8s/deployment.yaml": [
      "COMPONENTNAME"
    ],
    "supervisor/component.conf": [
      "BINNAME",
      "COMPONENTNAME"
    ],
    "test-configs/standalone-messaging.json": [
      "COMPONENTNAME"
    ],
    "tests/conftest.py": [
      "COMPONENTNAME"
    ],
    "tests/test_app.py": [
      "COMPONENTNAME"
    ]
  },
  "renames": [
    {
      "from": "app/greengrass_app.py",
      "to": "app/{COMPONENTNAME}.py"
    }
  ],
  "packs": {
    "GREENGRASS": [
      "recipe.yaml",
      "gdk-config.json"
    ],
    "HOST": [
      "compose.yaml",
      "supervisor",
      "Dockerfile"
    ],
    "KUBERNETES": [
      "Dockerfile",
      "k8s"
    ]
  },
  "conditional": []
}
