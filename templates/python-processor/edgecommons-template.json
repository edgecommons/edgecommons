  "renames": [
    {
      "from": "app/processor.py",
      "to": "app/{COMPONENTNAME}.py"
    }
  ],
  "packs": {
    "GREENGRASS": [
      "recipe.yaml",
      "gdk-config.json"
    ],
    "HOST": [
      "compose.yaml",
      "supervisor",
