{
  "schemaVersion": 2,
  "id": "python/processor",
  "language": "PYTHON",
  "kind": "processor",
  "description": "Python processing component: subscribe, transform through a pipeline of stages, forward.",
  "platforms": [
    "GREENGRASS",
    "HOST",
    "KUBERNETES"
  ],
  "requires": [
    "EDGECOMMONS_DEP"
  ],
  "substitutions": {
