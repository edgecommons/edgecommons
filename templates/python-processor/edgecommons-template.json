    ],
    "app/pipeline.py": [
      "COMPONENTNAME"
    ],
    "README.md": [
      "BINNAME",
      "COMPONENTFULLNAME",
      "COMPONENTNAME"
    ],
    "config.schema.json": [
      "COMPONENTNAME"
    ],
    "compose.yaml": [
      "BINNAME",
      "COMPONENTNAME"
    ],
    "supervisor/component.conf": [
      "BINNAME",
      "COMPONENTNAME"
    ],
    "Dockerfile": [
      "COMPONENTNAME"
    ],
    "k8s/configmap.yaml": [
      "BINNAME",
      "COMPONENTNAME"
    ],
    "k8s/deployment.yaml": [
      "COMPONENTNAME"
    ],
    "test-configs/config.json": [
      "BINNAME"
    ],
    "test-configs/standalone-messaging.json": [
      "BINNAME"
    ],
    "tests/test_connectivity.py": [
      "COMPONENTNAME"
    ],
    "docs/README.md": [
      "COMPONENTFULLNAME",
      "COMPONENTNAME"
    ],
    "docs/tutorial.md": [
      "BINNAME",
      "COMPONENTNAME"
    ],
    "docs/how-to-guides.md": [
      "BINNAME"
    ],
    "docs/sample-configurations.md": [
      "BINNAME"
    ],
    "docs/reference/configuration.md": [
      "BINNAME"
    ],
    "docs/reference/messaging-interface.md": [
      "BINNAME"
    ],
    "docs/reference/metrics.md": [
      "BINNAME"
