      "BINNAME",
      "COMPONENTFULLNAME",
      "DESCRIPTION"
    ],
    "gdk-config.json": [
      "AUTHOR",
      "BUCKET",
      "COMPONENTFULLNAME",
      "REGION"
    ],
    "main.py": [
      "COMPONENTFULLNAME",
      "COMPONENTNAME"
    ],
    "app/processor.py": [
