{
  "logging": { "level": "DEBUG", "ts_format": "{timestamp} [{level}] {logger}: {message}" },
  "hierarchy": { "levels": ["site", "device"] },
  "identity": { "site": "factory-1" },
  "heartbeat": {
    "enabled": true,
    "intervalSecs": 5,
    "measures": { "cpu": true, "memory": true },
    "destination": "local"
  },
  "metricEmission": { "target": "log", "namespace": "edgecommons" },
  "tags": { "site": "factory-1" },
  "component": {
    "global": {
      "defaults": { "tickMs": 10000, "maxQueue": 256 }
    },
    "instances": [
      {
        "id": "rollup",
        "subscribe": ["ecv1/+/+/+/data/#"],
        "publishTopic": "ecv1/gw-01/<<BINNAME>>/rollup/app/summary",
        "target": "local",
        "pipeline": [
          { "fieldEquals": { "path": "signal.id", "value": "temperature-1" } },
          { "countPerTick": {} }
        ],
        "tickMs": 10000
      }
    ]
  }
}
