# Resolve the @mbreissi scope from GitHub Packages (where @edgecommons/ggcommons is published).
# Only emitted for `--dep-source registry`. Auth comes from the NODE_AUTH_TOKEN env var
# (a GitHub token with read:packages) — npm expands ${NODE_AUTH_TOKEN} at install, so no
# secret is stored in this file. For a local checkout use `--dep-source local` (a file: dep,
# no registry needed) and this file is not generated.
@edgecommons:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
