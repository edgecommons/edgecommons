{
  "language": "TYPESCRIPT",
  "description": "TypeScript Greengrass component built on the edgecommons TypeScript library.",
  "required": ["EDGECOMMONS_DEP"],
  "substitutions": {
    "package.json": ["COMPONENTNAME", "DESCRIPTION", "EDGECOMMONS_DEP"],
    "recipe.yaml": ["DESCRIPTION", "COMPONENTFULLNAME", "AUTHOR", "COMPONENTNAME"],
    "gdk-config.json": ["COMPONENTFULLNAME", "AUTHOR", "BUCKET", "REGION"],
    "build.sh": ["COMPONENTFULLNAME", "COMPONENTNAME"],
    "src/main.ts": ["COMPONENTFULLNAME", "COMPONENTNAME"],
    "src/app.ts": ["COMPONENTNAME"],
    "README.md": ["COMPONENTNAME", "COMPONENTFULLNAME"],
    "k8s/configmap.yaml": ["COMPONENTNAME", "COMPONENTFULLNAME"],
    "k8s/deployment.yaml": ["COMPONENTNAME"]
  },
  "renames": [],
  "conditional": [
    {"when": "platform:KUBERNETES", "paths": ["Dockerfile", "k8s"]},
    {"when": "dep:registry", "paths": [".npmrc"]}
  ]
}
