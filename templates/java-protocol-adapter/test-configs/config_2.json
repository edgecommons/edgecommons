{
  "logging": {
    "level": "INFO",
    "java_format": "%d{yyyy-MM-dd HH:mm:ss.SSS} [%-5p] %C{1} (%L) [%t] : %m%n"
  },
  "heartbeat": {
    "enabled": true,
    "intervalSecs": 5,
    "destination": "local",
    "measures": {
      "cpu": true,
      "memory": true,
      "disk": false,
      "files": true,
      "threads": true,
      "fds": true
    }
  },
  "hierarchy": {
    "levels": ["site", "device"]
  },
  "identity": {
    "site": "site1"
  },
  "tags": {
    "appId": "IntelliJIdea",
    "shop": "shop1",
    "line": "line1"
  },
  "metricEmission": {
    "target": "log",
    "targetConfig": {
      "logFileName": "{ComponentFullName}.metric.log"
    }
  },
  "component": {
    "global": {
      "publish_interval": 3,
      "message": "Hello world config_2!"
    },
    "instances": []
  }
}
