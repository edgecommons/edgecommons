{
  "logging": {
    "level": "INFO",
    "java_format": "%d{yyyy-MM-dd HH:mm:ss.SSS} [%-5p] %C{1} (%L) [%t] : %m%n"
  },
  "heartbeat": {
    "intervalSecs": 5,
    "measures": {
      "cpu": true,
      "memory": true,
      "disk": false,
      "files": true,
      "threads": true,
      "fds": true
    },
    "targets": [
      {
        "type": "messaging",
        "config": {
          "destination": "ipc"
        }
      }
    ]
  },
  "tags": {
    "appId": "IntelliJIdea",
    "site": "site1",
    "shop": "shop1",
    "line": "line1"
  },
  "metricEmission": {
    "target": "log",
    "targetConfig": {
      "logFileName": "{ComponentFullName}.metric.log"
    }
  },
  "component": {
    "global": {
      "publish_interval": 3,
      "message": "Hello world config_2!"
    },
    "instances": [
    ]
  }
}