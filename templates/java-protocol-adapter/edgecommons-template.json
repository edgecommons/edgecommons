{
  "schemaVersion": 2,
  "id": "java/protocol-adapter",
  "language": "JAVA",
  "kind": "protocol-adapter",
  "description": "Java southbound protocol adapter: a DeviceSession/DeviceBackend seam with an in-process sim, connect to devices, publish SouthboundSignalUpdate, serve the sb/* command family + edge-console panels, and emit southbound_health.",
  "platforms": [
    "GREENGRASS",
    "HOST",
    "KUBERNETES"
  ],
  "substitutions": {
    "compose.yaml": [
      "BINNAME",
      "COMPONENTNAME",
      "JARNAME"
    ],
    "config.schema.json": [
      "COMPONENTNAME"
    ],
    "Dockerfile": [
      "JARNAME"
    ],
    "gdk-config.json": [
      "AUTHOR",
      "BUCKET",
      "COMPONENTFULLNAME",
      "REGION"
    ],
    "pom.xml": [
      "COMPONENTNAME",
      "EDGECOMMONS_VERSION",
      "JARNAME",
      "MAINCLASSNAME",
      "PACKAGE"
    ],
    "README.md": [
      "COMPONENTFULLNAME",
      "COMPONENTNAME",
      "JARNAME"
    ],
    "recipe.yaml": [
      "AUTHOR",
      "COMPONENTFULLNAME",
      "DESCRIPTION",
      "JARNAME",
      "MAINCLASSNAME"
    ],
    "k8s/configmap.yaml": [
      "COMPONENTNAME"
    ],
    "k8s/deployment.yaml": [
      "COMPONENTNAME"
    ],
    "src/main/java/com/mbreissi/testcomponent/App.java": [
      "COMPONENTFULLNAME",
      "COMPONENTNAME",
      "PACKAGE"
    ],
    "src/main/java/com/mbreissi/testcomponent/Device.java": [
      "PACKAGE"
    ],
    "src/main/java/com/mbreissi/testcomponent/Metrics.java": [
      "COMPONENTNAME",
      "PACKAGE"
    ],
    "src/main/java/com/mbreissi/testcomponent/Commands.java": [
      "COMPONENTNAME",
      "PACKAGE"
    ],
    "src/test/java/com/mbreissi/testcomponent/AppTest.java": [
      "COMPONENTNAME",
      "PACKAGE"
    ],
    "src/test/java/com/mbreissi/testcomponent/DeviceTest.java": [
      "PACKAGE"
    ],
    "src/test/java/com/mbreissi/testcomponent/MetricsTest.java": [
      "PACKAGE"
    ],
    "src/test/java/com/mbreissi/testcomponent/CommandsTest.java": [
      "COMPONENTNAME",
      "PACKAGE"
    ],
    "supervisor/component.conf": [
      "BINNAME",
      "COMPONENTNAME",
      "JARNAME"
    ],
    "test-configs/standalone-messaging.json": [
      "COMPONENTNAME"
    ]
  },
  "packs": {
    "GREENGRASS": [
      "recipe.yaml",
      "gdk-config.json"
    ],
    "HOST": [
      "compose.yaml",
      "supervisor",
      "Dockerfile"
    ],
    "KUBERNETES": [
      "Dockerfile",
      "k8s"
    ]
  },
  "conditional": [],
  "renames": [
    {
      "from": "src/main/java/com/mbreissi/testcomponent",
      "to": "src/main/java/{PACKAGEPATH}"
    },
    {
      "from": "src/main/java/{PACKAGEPATH}/App.java",
      "to": "src/main/java/{PACKAGEPATH}/{COMPONENTNAME}.java"
    },
    {
      "from": "src/test/java/com/mbreissi/testcomponent",
      "to": "src/test/java/{PACKAGEPATH}"
    },
    {
      "from": "src/test/java/{PACKAGEPATH}/AppTest.java",
      "to": "src/test/java/{PACKAGEPATH}/{COMPONENTNAME}Test.java"
    },
    {
      "from": "test-configs/TestComponent.json",
      "to": "test-configs/{COMPONENTNAME}.json"
    }
  ]
}
