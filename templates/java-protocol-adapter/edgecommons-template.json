{
  "language": "JAVA",
  "description": "Java protocol-adapter component (southbound device->cloud bridge) built on the edgecommons Java library and the southbound contract (docs/SOUTHBOUND.md).",
  "substitutions": {
    "recipe.yaml": ["DESCRIPTION", "COMPONENTFULLNAME", "AUTHOR", "JARNAME", "MAINCLASSNAME"],
    "gdk-config.json": ["COMPONENTFULLNAME", "AUTHOR", "BUCKET", "REGION"],
    "pom.xml": ["PACKAGE", "JARNAME", "COMPONENTNAME", "MAINCLASSNAME", "EDGECOMMONS_VERSION"],
    "src/main/java/com/mbreissi/testcomponent/App.java": ["PACKAGE", "COMPONENTNAME", "COMPONENTFULLNAME"],
    "README.md": ["COMPONENTNAME", "COMPONENTFULLNAME", "JARNAME"],
    "Dockerfile": ["JARNAME"],
    "k8s/configmap.yaml": ["COMPONENTNAME", "COMPONENTFULLNAME"],
    "k8s/deployment.yaml": ["COMPONENTNAME"]
  },
  "conditional": [
    {"when": "platform:KUBERNETES", "paths": ["Dockerfile", "k8s"]}
  ],
  "renames": [
    {"from": "src/main/java/com/mbreissi/testcomponent", "to": "src/main/java/{PACKAGEPATH}"},
    {"from": "src/main/java/{PACKAGEPATH}/App.java", "to": "src/main/java/{PACKAGEPATH}/{COMPONENTNAME}.java"},
    {"from": "test-configs/TestComponent.json", "to": "test-configs/{COMPONENTNAME}.json"}
  ]
}
