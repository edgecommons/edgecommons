  "validCatalogs": [
    {
      "name": "four-layer-line-with-one-device",
      "catalog": {
        "schemaVersion": 1,
        "version": "enterprise-site-zone-line-v1",
        "provenance": {
          "source": "file",
          "uri": "/etc/edgecommons/catalog.json"
        },
        "hierarchy": {
          "levels": ["enterprise", "site", "zone", "line", "device"]
        },
        "nodes": {
          "enterprise/acme": {
            "scope": { "enterprise": "acme" },
            "config": {
              "hierarchy": {
                "levels": ["enterprise", "site", "zone", "line", "device"]
              },
              "identity": { "enterprise": "acme" },
              "logging": { "level": "INFO" },
              "tags": { "owner": "central-ops" }
            }
          },
          "site/dallas": {
            "parent": "enterprise/acme",
            "scope": { "enterprise": "acme", "site": "dallas" },
            "config": {
              "identity": { "site": "dallas" },
              "metricEmission": {
                "target": "log",
                "namespace": "edgecommons"
              }
            }
          },
          "zone/packaging": {
            "parent": "site/dallas",
            "scope": {
              "enterprise": "acme",
              "site": "dallas",
              "zone": "packaging"
            },
            "config": {
              "identity": { "zone": "packaging" },
              "tags": { "zoneClass": "packaging" }
            }
          },
          "line/line-7": {
            "parent": "zone/packaging",
            "scope": {
              "enterprise": "acme",
              "site": "dallas",
              "zone": "packaging",
              "line": "line-7"
            },
            "config": {
              "identity": { "line": "line-7" },
              "logging": { "level": "WARN" },
              "heartbeat": { "intervalSecs": 10 }
            }
          }
        },
        "components": {
          "opcua-adapter": {
            "parent": "line/line-7",
            "config": {
              "component": {
                "token": "opcua-adapter",
                "global": {
                  "endpoint": "opc.tcp://10.10.7.20:4840",
                  "publish_interval": 3
                },
                "instances": []
              },
              "logging": { "level": "DEBUG" },
              "tags": { "componentMarker": "opcua" }
            }
          },
          "modbus-adapter": {
            "parent": "line/line-7",
            "config": {
              "component": {
                "token": "modbus-adapter",
                "global": {
                  "endpoint": "tcp://10.10.7.21:502",
                  "publish_interval": 3
                },
                "instances": []
              },
              "tags": { "componentMarker": "modbus" }
            }
          }
        }
      },
      "request": { "component": "opcua-adapter" },
      "expected": {
        "version": "enterprise-site-zone-line-v1",
        "componentCount": 2,
        "lineageIds": [
          "enterprise/acme",
          "site/dallas",
          "zone/packaging",
          "line/line-7",
          "component/opcua-adapter"
        ],
        "pushTopics": [
          "ecv1/line-7-edge-01/opcua-adapter/main/cmd/set-config",
          "ecv1/line-7-edge-01/modbus-adapter/main/cmd/set-config"
        ]
      }
    },
