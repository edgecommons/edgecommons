          "opcua-adapter": {
            "parent": "line/line-8",
            "config": {
              "component": {
                "token": "opcua-adapter",
                "global": { "publish_interval": 1 },
                "instances": []
              }
            }
          },
          "modbus-adapter": {
            "parent": "line/line-8",
            "config": {
              "component": {
                "token": "modbus-adapter",
                "global": { "publish_interval": 1 },
                "instances": []
              }
            }
          }
        }
      },
      "expected": {
        "promote": true,
        "persist": false,
        "pushCount": 2,
        "pushedVersion": "enterprise-site-zone-line-v2"
      }
    }
