{
  "description": "edgecommons CONFIG_COMPONENT lineage bundle conformance vectors",
  "cases": [
    {
      "name": "enterprise-site-zone-line-component",
      "input": {
        "requestComponent": "opcua-adapter",
        "body": {
          "lineageVersion": 1,
          "catalogVersion": "enterprise-site-zone-line-v1",
          "component": "opcua-adapter",
          "provenance": {
            "source": "file",
            "uri": "/etc/edgecommons/catalog.json"
          },
          "layers": [
            {
              "id": "enterprise/acme",
              "kind": "scope",
              "scope": { "enterprise": "acme" },
              "config": {
                "hierarchy": {
                  "levels": ["enterprise", "site", "zone", "line", "device"]
                },
                "identity": { "enterprise": "acme" },
                "logging": { "level": "INFO" }
              }
            },
            {
              "id": "site/dallas",
              "kind": "scope",
              "scope": { "enterprise": "acme", "site": "dallas" },
              "config": {
                "identity": { "site": "dallas" },
                "metricEmission": {
                  "target": "log",
                  "namespace": "edgecommons"
                }
              }
            },
            {
              "id": "zone/packaging",
              "kind": "scope",
              "scope": {
                "enterprise": "acme",
                "site": "dallas",
                "zone": "packaging"
              },
              "config": {
                "identity": { "zone": "packaging" },
                "tags": { "zoneClass": "packaging" }
              }
            },
            {
              "id": "line/line-7",
              "kind": "scope",
              "scope": {
                "enterprise": "acme",
                "site": "dallas",
                "zone": "packaging",
                "line": "line-7"
              },
              "config": {
                "identity": { "line": "line-7" },
                "logging": { "level": "WARN" },
                "heartbeat": { "intervalSecs": 10 }
              }
            },
            {
              "id": "component/opcua-adapter",
              "kind": "component",
              "component": "opcua-adapter",
              "config": {
                "component": {
                  "token": "opcua-adapter",
                  "global": {
                    "endpoint": "opc.tcp://10.10.7.20:4840",
                    "publish_interval": 3
                  },
                  "instances": []
                },
                "logging": { "level": "DEBUG" },
                "tags": { "componentMarker": "opcua" }
              }
            }
          ]
        }
      },
      "expected": {
        "effective": {
          "hierarchy": {
            "levels": ["enterprise", "site", "zone", "line", "device"]
          },
          "identity": {
            "enterprise": "acme",
            "site": "dallas",
            "zone": "packaging",
            "line": "line-7"
          },
          "logging": { "level": "DEBUG" },
          "metricEmission": {
            "target": "log",
            "namespace": "edgecommons"
          },
          "tags": {
            "zoneClass": "packaging",
            "componentMarker": "opcua"
          },
          "heartbeat": { "intervalSecs": 10 },
          "component": {
            "token": "opcua-adapter",
            "global": {
              "endpoint": "opc.tcp://10.10.7.20:4840",
              "publish_interval": 3
            },
            "instances": []
          }
        }
      }
    },
    {
