{
  "schemaVersion": 1,
  "version": "bottles-r-us-dallas-site-initial",
  "provenance": {
    "source": "file",
    "uri": "/config/config-catalog.json"
  },
  "hierarchy": {
    "levels": [
      "enterprise",
      "site",
      "device"
    ]
  },
  "nodes": {
    "enterprise/bottles-r-us": {
      "scope": {
        "enterprise": "bottles-r-us"
      },
      "config": {
        "hierarchy": {
          "levels": [
            "enterprise",
            "site",
            "device"
          ]
        },
        "identity": {
          "enterprise": "bottles-r-us"
        },
        "tags": {
          "appId": "bottling-plant",
          "scenario": "bottling-company-test"
        },
        "logging": {
          "level": "INFO",
          "publish": {
            "enabled": true,
            "destination": "local",
            "minLevel": "INFO"
          }
        },
        "heartbeat": {
          "enabled": true,
          "intervalSecs": 30,
          "measures": {
            "cpu": true,
            "memory": false,
            "threads": true,
            "files": true,
            "fds": true
          }
        },
        "metricEmission": {
          "target": "messaging"
        }
      }
    },
    "site/dallas": {
      "parent": "enterprise/bottles-r-us",
      "scope": {
        "enterprise": "bottles-r-us",
        "site": "dallas"
      },
      "config": {
        "identity": {
          "site": "dallas"
        },
        "heartbeat": {
          "intervalSecs": 15,
          "measures": {
            "cpu": true,
            "memory": true,
            "threads": true,
            "files": true,
            "fds": true
          }
        }
      }
    }
  },
  "components": {
    "EdgeConsole": {
      "parent": "site/dallas",
      "config": {
        "messaging": {
          "local": {
            "host": "localhost",
            "port": 1883,
            "clientId": "edge-console"
          },
          "requestTimeoutSeconds": 30
        },
        "heartbeat": {
          "intervalSecs": 5,
          "measures": {
            "cpu": true,
            "memory": true,
            "threads": true,
            "files": true,
            "fds": true
          }
        },
        "component": {
          "token": "edge-console",
          "global": {
            "console": {
              "ws": {
                "port": 8443,
                "bindAddress": "0.0.0.0",
                "heartbeatIntervalMs": 15000,
                "webRoot": "/app/edge-console/ui/dist"
              },
              "apps": [
                {
                  "id": "dallas-line-1",
                  "webRoot": "apps/dallas-operations",
                  "allowedOrigins": [
                    "http://127.0.0.1:8080"
                  ],
                  "allowedRoles": [
                    "operator"
                  ],
                  "capabilities": [
                    "signals",
                    "alarms"
                  ]
                },
                {
                  "id": "dallas-line-2",
                  "webRoot": "apps/dallas-operations",
                  "allowedOrigins": [
                    "http://127.0.0.1:8080"
                  ],
                  "allowedRoles": [
                    "operator"
                  ],
                  "capabilities": [
                    "signals",
                    "alarms"
                  ]
                },
                {
                  "id": "tv-board",
                  "webRoot": "apps/tv-board",
                  "allowedOrigins": [
                    "http://127.0.0.1:8080",
                    "http://192.168.1.224:8080",
                    "file://",
                    "null",
                    "https://google-tv.edgecommons.local"
                  ],
                  "allowedRoles": [
                    "operator"
                  ],
                  "capabilities": [
                    "signals",
                    "alarms"
                  ]
                }
              ],
              "staleness": {
                "warnMultiplier": 2,
                "staleMultiplier": 2.5,
                "offlineMultiplier": 5,
                "defaultIntervalSecs": 5,
                "sweepIntervalMs": 1000
              },
              "cache": {
                "maxChannelsPerComponent": 1024
              },
              "runtime": {
                "workerThreads": 4,
                "mallocArenaMax": 2,
                "eventBufferCapacity": 512
              }
            }
          },
          "instances": [
            {
              "id": "main"
            }
          ]
        }
      }
    }
  }
}
