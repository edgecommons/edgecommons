{
  "schemaVersion": 1,
  "version": "bottles-r-us-dallas-packaging-line-initial",
  "provenance": {
    "source": "file",
    "uri": "/run/config/config-catalog.json"
  },
  "hierarchy": {
    "levels": [
      "enterprise",
      "site",
      "line",
      "device"
    ]
  },
  "nodes": {
    "enterprise/bottles-r-us": {
      "scope": {
        "enterprise": "bottles-r-us"
      },
      "config": {
        "hierarchy": {
          "levels": [
            "enterprise",
            "site",
            "line",
            "device"
          ]
        },
        "identity": {
          "enterprise": "bottles-r-us"
        },
        "tags": {
          "appId": "bottling-plant",
          "scenario": "bottling-company-test"
        },
        "logging": {
          "level": "INFO",
          "publish": {
            "enabled": true,
            "destination": "local",
            "minLevel": "INFO"
          }
        },
        "heartbeat": {
          "enabled": true,
          "intervalSecs": 30,
          "measures": {
            "cpu": true,
            "memory": false,
            "threads": true,
            "files": true,
            "fds": true
          }
        },
        "metricEmission": {
          "target": "messaging"
        }
      }
    },
    "site/dallas": {
      "parent": "enterprise/bottles-r-us",
      "scope": {
        "enterprise": "bottles-r-us",
        "site": "dallas"
      },
      "config": {
        "identity": {
          "site": "dallas"
        },
        "heartbeat": {
          "intervalSecs": 15,
          "measures": {
            "cpu": true,
            "memory": true,
            "threads": true,
            "files": true,
            "fds": true
          }
        }
      }
    },
    "line/packaging-line": {
      "parent": "site/dallas",
      "scope": {
        "enterprise": "bottles-r-us",
        "site": "dallas",
        "line": "packaging-line"
      },
      "config": {
        "identity": {
          "line": "packaging-line"
        },
        "heartbeat": {
          "intervalSecs": 5,
          "measures": {
            "cpu": true,
            "memory": true,
            "threads": true,
            "files": true,
            "fds": true
          }
        }
      }
    }
  },
  "components": {
    "OpcUaAdapter": {
      "parent": "line/packaging-line",
      "config": {
        "metricEmission": {
          "targetConfig": {
            "destination": "local"
          }
        },
        "component": {
          "token": "opcua-adapter",
          "global": {
            "defaults": {
              "publishIntervalMs": 500,
              "samplingRateMs": 200,
              "queueSize": 20
            }
          },
          "instances": [
            {
              "id": "palletizer1",
              "connection": {
                "endpoint": "opc.tcp://192.168.1.180:49320",
                "securityPolicy": "None"
              },
              "publish": {
                "batchMs": 0
              },
              "subscriptions": [
                {
                  "id": "live",
                  "include": [
                    {
                      "namespaceUri": "Kepware Server",
                      "match": "^GGCommonsTest\\.Device1\\.Live.*",
                      "samplingRateMs": 200,
                      "queueSize": 20
                    }
                  ],
                  "exclude": []
                }
              ]
            }
          ]
        }
      }
    },
    "ModbusAdapter": {
      "parent": "line/packaging-line",
      "config": {
        "component": {
          "token": "modbus-adapter",
          "global": {
            "defaults": {
              "pollIntervalMs": 500,
              "publishMode": "always",
              "batchMs": 0,
              "maxGap": 4
            }
          },
          "instances": [
            {
              "id": "casepacker1",
              "connection": {
                "transport": "tcp",
                "host": "192.168.1.224",
                "port": 5021,
                "unitId": 1,
                "timeoutMs": 1000
              },
              "publish": {
                "batchMs": 0
              },
              "write": {
                "enabled": false
              },
              "pollGroups": [
                {
                  "id": "main",
                  "pollIntervalMs": 500,
                  "publishMode": "always",
                  "signals": [
                    {
                      "name": "GoodCaseCount",
                      "table": "input",
                      "address": 0,
                      "type": "uint32"
                    },
                    {
                      "name": "CaseRejectCount",
                      "table": "input",
                      "address": 2,
                      "type": "uint32"
                    },
                    {
                      "name": "PackerMotorCurrentA",
                      "table": "input",
                      "address": 4,
                      "type": "uint16",
                      "scale": 0.01
                    },
                    {
                      "name": "CaseWeightKg",
                      "table": "input",
                      "address": 5,
                      "type": "uint16",
                      "scale": 0.01
                    },
                    {
                      "name": "CaseRateCpm",
                      "table": "input",
                      "address": 6,
                      "type": "uint16",
                      "scale": 0.1
                    },
                    {
                      "name": "CartonMagazinePct",
                      "table": "input",
                      "address": 7,
                      "type": "uint16",
                      "scale": 0.1
                    },
                    {
                      "name": "JamStatus",
                      "table": "discrete",
                      "address": 0,
                      "type": "bool"
                    },
                    {
                      "name": "MagazineLow",
                      "table": "discrete",
                      "address": 1,
                      "type": "bool"
                    },
                    {
                      "name": "CaseAtDischarge",
                      "table": "discrete",
                      "address": 2,
                      "type": "bool"
                    },
                    {
                      "name": "EStopHealthy",
                      "table": "discrete",
                      "address": 3,
                      "type": "bool"
                    },
                    {
                      "name": "RunCommand",
                      "table": "coil",
                      "address": 0,
                      "type": "bool"
                    }
                  ]
                }
              ]
            }
          ]
        }
      }
    },
    "TelemetryProcessor": {
      "parent": "line/packaging-line",
      "config": {
        "component": {
          "token": "telemetry-processor",
          "global": {
            "defaults": {
              "key": "body.signal.id",
              "scriptEngine": "lua",
              "scriptsDir": "/scripts"
            }
          },
          "instances": [
            {
              "id": "oee-availability",
              "subscribe": [
                "ecv1/{ThingName}/opcua-adapter/palletizer1/data/#"
              ],
              "pipeline": [
                {
                  "filter": {
                    "quality": "GOOD"
                  }
                },
                {
                  "filter": {
                    "field": "body.signal.name",
                    "op": "eq",
                    "value": "OeeShiftSnapshot"
                  }
                },
                {
                  "sample": {
                    "everyMs": 1000,
                    "by": "body.signal.id"
                  }
                },
                {
                  "script": {
                    "file": "oee/availability.lua"
                  }
                }
              ],
              "target": "local",
              "publish": {
                "topic": "ecv1/{ThingName}/telemetry-processor/main/data/gemba/oee/availability"
              }
            },
            {
              "id": "oee-performance",
              "subscribe": [
                "ecv1/{ThingName}/opcua-adapter/palletizer1/data/#"
              ],
              "pipeline": [
                {
                  "filter": {
                    "quality": "GOOD"
                  }
                },
                {
                  "filter": {
                    "field": "body.signal.name",
                    "op": "eq",
                    "value": "OeeShiftSnapshot"
                  }
                },
                {
                  "sample": {
                    "everyMs": 1000,
                    "by": "body.signal.id"
                  }
                },
                {
                  "script": {
                    "file": "oee/performance.lua"
                  }
                }
              ],
              "target": "local",
              "publish": {
                "topic": "ecv1/{ThingName}/telemetry-processor/main/data/gemba/oee/performance"
              }
            },
            {
              "id": "oee-quality",
              "subscribe": [
                "ecv1/{ThingName}/opcua-adapter/palletizer1/data/#"
              ],
              "pipeline": [
                {
                  "filter": {
                    "quality": "GOOD"
                  }
                },
                {
                  "filter": {
                    "field": "body.signal.name",
                    "op": "eq",
                    "value": "OeeShiftSnapshot"
                  }
                },
                {
                  "sample": {
                    "everyMs": 1000,
                    "by": "body.signal.id"
                  }
                },
                {
                  "script": {
                    "file": "oee/quality.lua"
                  }
                }
              ],
              "target": "local",
              "publish": {
                "topic": "ecv1/{ThingName}/telemetry-processor/main/data/gemba/oee/quality"
              }
            },
            {
              "id": "oee-overall",
              "subscribe": [
                "ecv1/{ThingName}/opcua-adapter/palletizer1/data/#"
              ],
              "pipeline": [
                {
                  "filter": {
                    "quality": "GOOD"
                  }
                },
                {
                  "filter": {
                    "field": "body.signal.name",
                    "op": "eq",
                    "value": "OeeShiftSnapshot"
                  }
                },
                {
                  "sample": {
                    "everyMs": 1000,
                    "by": "body.signal.id"
                  }
                },
                {
                  "script": {
                    "file": "oee/oee.lua"
                  }
                }
              ],
              "target": "local",
              "publish": {
                "topic": "ecv1/{ThingName}/telemetry-processor/main/data/gemba/oee/overall"
              }
            }
          ]
        }
      }
    },
    "UnsBridge": {
      "parent": "line/packaging-line",
      "config": {
        "messaging": {
          "local": {
            "host": "localhost",
            "port": 1883,
            "clientId": "pack-bridge-local"
          },
          "requestTimeoutSeconds": 30
        },
        "component": {
          "token": "uns-bridge",
          "instances": [
            {
              "id": "site",
              "siteBroker": {
                "host": "dallas-site",
                "port": 1883,
                "clientId": "pack-bridge-site"
              },
              "uplink": {
                "classes": {
                  "state": {
                    "enabled": true
                  },
                  "cfg": {
                    "enabled": true
                  },
                  "evt": {
                    "enabled": true,
                    "bufferWhileDisconnected": {
                      "maxMessages": 1000
                    }
                  },
                  "metric": {
                    "enabled": true,
                    "maxRatePerSec": 50
                  },
                  "data": {
                    "enabled": true,
                    "maxRatePerSec": 200,
                    "burst": 400
                  },
                  "log": {
                    "enabled": true,
                    "maxRatePerSec": 50
                  },
                  "app": {
                    "enabled": false
                  }
                }
              },
              "reply": {
                "ttlSecs": 60,
                "maxPending": 1024
              },
              "maxHops": 4,
              "queue": {
                "data": 512,
                "default": 64
              }
            }
          ]
        }
      }
    }
  }
}
