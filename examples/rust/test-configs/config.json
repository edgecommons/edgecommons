{
  "logging": { "level": "DEBUG" },
  "heartbeat": {
    "intervalSecs": 5,
    "measures": { "cpu": true, "memory": true },
    "targets": [ { "type": "metric" } ]
  },
  "metricEmission": { "target": "log", "namespace": "ggcommons" },
  "credentials": {
    "vault": {
      "path": "./.vault/vault",
      "keyProvider": { "type": "file", "keyPath": "./.vault/vault.key" }
    }
  },
  "tags": { "site": "factory-1" },
  "component": {
    "global": { "publish_interval": 3 },
    "instances": [ { "id": "main" } ]
  }
}
