{
  "logging": { "level": "DEBUG", "rust_format": "{timestamp} [{level}] {target} - {message}" },
  "heartbeat": {
    "enabled": true,
    "intervalSecs": 5,
    "measures": { "cpu": true, "memory": true },
    "destination": "local"
  },
  "metricEmission": { "target": "log", "namespace": "ggcommons" },
  "credentials": {
    "vault": {
      "path": "./.vault/vault",
      "keyProvider": { "type": "file", "keyPath": "./.vault/vault.key" }
    }
  },
  "parameters": {
    "source": { "type": "env", "prefix": "GG_PARAM_" },
    "refreshIntervalSecs": 0,
    "sync": { "names": ["/skeleton/region", "/skeleton/poolSize"] }
  },
  "tags": { "site": "factory-1" },
  "component": {
    "global": { "publish_interval": 3 },
    "instances": [ { "id": "main" } ]
  }
}
