{
  "logging": {
    "level": "INFO"
  },
  "heartbeat": {
    "enabled": true,
    "intervalSecs": 1,
    "measures": {
      "cpu": true,
      "memory": true,
      "disk": false,
      "files": false,
      "threads": true,
      "fds": false
    },
    "destination": "local"
  },
  "metricEmission": {
    "target": "log",
    "namespace": "ggcommons",
    "targetConfig": {
      "logFileName": "skeleton_test.metric.log"
    }
  },
  "tags": {
    "site": "site1",
    "line": "line1"
  },
  "component": {
    "global": {
      "publish_interval": 1
    },
    "instances": []
  }
}
