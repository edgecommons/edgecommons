{
  "logging": {
    "level": "INFO",
    "python_format": "%(asctime)s [%(levelname)s] %(filename)s %(funcName)s(%(lineno)d) [%(threadName)s]: %(message)s"
  },
  "heartbeat": {
    "intervalSecs": 1,
    "targets": [
      {
        "type": "messaging",
        "config": {
          "destination": "ipc",
          "topic": "{ThingName}/{ComponentName}/heartbeat"
        }
      }
    ],
    "measures": {
      "cpu": true,
      "memory": true,
      "disk": false,
      "files": true,
      "threads": true,
      "fds": false
    }
  },
  "metricEmission": {
	"target" : "messaging",
    "namespace": "ggcommons",
	"targetConfig" : {
      "destination": "ipc",
      "intervalSecs": 10
    }
  },
  "tags": {
    "appId": "IntelliJIdea",
    "site": "site1",
    "shop": "shop1",
    "line": "line1"
  },
  "component": {
    "global": {
      "publish_interval": 2
    },
    "instances": [
    ]
  }
}