{
  "logging": {
    "level": "INFO",
    "format": "%(asctime)s [%(levelname)s] %(filename)s %(funcName)s(%(lineno)d) [%(threadName)s]: %(message)s"
  },
  "credentials": {
    "vault": {
      "path": "./.vault/vault",
      "keyProvider": { "type": "file", "keyPath": "./.vault/vault.key" }
    }
  },
  "parameters": {
    "source": { "type": "env", "prefix": "GG_PARAM_" },
    "refreshIntervalSecs": 300,
    "sync": { "names": ["/skeleton/region", "/skeleton/poolSize"] }
  },
  "component": {
    "global": {
      "publish_interval": 3
    },
    "instances": [
    ]
  }
}