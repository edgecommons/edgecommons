{
  "logging": {
    "level": "INFO",
    "format": "%d{yyyy-MM-dd HH:mm:ss} [%-5p] %-25.25c{1}(%4L): %m%n"
  },
  "heartbeat": {
    "topic": "heartbeat/{ThingName}/{ComponentName}",
    "intervalSecs": 5,
    "metric": {
      "cpu": true,
      "memory": true,
      "disk": false
    }
  },
  "tags": {
    "appId": "ABC12345",
    "site": "site1",
    "shop": "shop1",
    "line": "line1"
  },
  "component": {
    "global": {
      "publish_interval": 3,
      "message": "Hello World config_1!"
    },
    "instances": [
      {
        "id":  "first",
        "param1": "dummy1"
      },
      {
        "id": "second",
        "param1": "dummy2"
      }
    ]
  }
}