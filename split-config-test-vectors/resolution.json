{
  "description": "edgecommons split-config shared-layer resolution conformance vectors",
  "cases": [
    {
      "name": "file-extends-relative",
      "provider": "FILE",
      "input": {
        "componentPath": "/etc/edgecommons/config.json",
        "componentLayer": { "extends": "shared.json" }
      },
      "expected": { "basePath": "/etc/edgecommons/shared.json", "missingDefaultIsNoop": false }
    },
    {
      "name": "file-env-var-path",
      "provider": "FILE",
      "input": {
        "componentPath": "/app/config.json",
        "env": { "EDGECOMMONS_SHARED_CONFIG": "/etc/edgecommons/base.json" },
        "componentLayer": {}
      },
      "expected": { "basePath": "/etc/edgecommons/base.json", "missingDefaultIsNoop": false }
    },
    {
      "name": "file-conventional-missing-noop",
      "provider": "FILE",
      "input": {
        "componentPath": "/app/config.json",
        "componentLayer": {}
      },
      "expected": { "basePath": "/etc/edgecommons/shared.json", "missingDefaultIsNoop": true }
    },
    {
      "name": "configmap-extends-relative",
      "provider": "CONFIGMAP",
      "input": {
        "mountDir": "/etc/edgecommons",
        "componentPath": "/etc/edgecommons/config.json",
        "componentLayer": { "extends": "shared.json" }
      },
      "expected": { "basePath": "/etc/edgecommons/shared.json", "watchDirectory": "/etc/edgecommons" }
    },
    {
      "name": "configmap-mounted-shared-default",
      "provider": "CONFIGMAP",
      "input": {
        "mountDir": "/var/run/edgecommons-config",
        "componentPath": "/var/run/edgecommons-config/config.json",
        "componentLayer": {}
      },
      "expected": { "basePath": "/var/run/edgecommons-config/shared.json", "missingDefaultIsNoop": true }
    },
    {
      "name": "env-inline-json",
      "provider": "ENV",
      "input": {
        "env": { "EDGECOMMONS_SHARED_CONFIG": "{\"logging\":{\"level\":\"INFO\"}}" }
      },
      "expected": { "inline": true, "base": { "logging": { "level": "INFO" } } }
    },
    {
      "name": "env-at-path",
      "provider": "ENV",
      "input": {
        "env": { "EDGECOMMONS_SHARED_CONFIG": "@/etc/edgecommons/shared.json" }
      },
      "expected": { "basePath": "/etc/edgecommons/shared.json" }
    },
    {
      "name": "gg-config-default-missing-noop",
      "provider": "GG_CONFIG",
      "input": {
        "env": {}
      },
      "expected": {
        "component": "com.mbreissi.edgecommons.EdgeCommonsSharedConfig",
        "key": "SharedComponentConfig",
        "missingDefaultIsNoop": true
      }
    },
    {
      "name": "gg-config-explicit-env-missing-fails",
      "provider": "GG_CONFIG",
      "input": {
        "env": { "EDGECOMMONS_SHARED_COMPONENT": "com.example.SharedConfig" }
      },
      "expected": {
        "component": "com.example.SharedConfig",
        "key": "SharedComponentConfig",
        "error": "SHARED_CONFIG_UNAVAILABLE"
      }
    },
    {
      "name": "shadow-missing-noop",
      "provider": "SHADOW",
      "input": {},
      "expected": {
        "shadowName": "edgecommons-shared",
        "key": "ComponentConfig",
        "missingDefaultIsNoop": true
      }
    }
  ]
}

