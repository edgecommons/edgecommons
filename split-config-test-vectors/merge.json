{
  "description": "edgecommons split-config merge conformance vectors",
  "cases": [
    {
      "name": "base-only-inherited",
      "input": {
        "base": {
          "hierarchy": { "levels": ["site", "device"] },
          "identity": { "site": "dallas" },
          "logging": { "level": "INFO" }
        },
        "component": {
          "component": { "token": "opcua-adapter" }
        }
      },
      "expected": {
        "effective": {
          "hierarchy": { "levels": ["site", "device"] },
          "identity": { "site": "dallas" },
          "logging": { "level": "INFO" },
          "component": { "token": "opcua-adapter" }
        }
      }
    },
    {
      "name": "component-overrides-scalar",
      "input": {
        "base": { "logging": { "level": "INFO" } },
        "component": {
          "logging": { "level": "DEBUG" },
          "component": { "token": "modbus-adapter" }
        }
      },
      "expected": {
        "effective": {
          "logging": { "level": "DEBUG" },
          "component": { "token": "modbus-adapter" }
        }
      }
    },
    {
      "name": "nested-object-deep-merge",
      "input": {
        "base": {
          "metricEmission": {
            "target": "log",
            "namespace": "edgecommons",
            "targetConfig": { "logFileName": "/var/log/shared-metrics.log" }
          }
        },
        "component": {
          "metricEmission": {
            "targetConfig": { "logFileName": "/tmp/component-metrics.log" }
          },
          "component": { "token": "telemetry-processor" }
        }
      },
      "expected": {
        "effective": {
          "metricEmission": {
            "target": "log",
            "namespace": "edgecommons",
            "targetConfig": { "logFileName": "/tmp/component-metrics.log" }
          },
          "component": { "token": "telemetry-processor" }
        }
      }
    },
    {
      "name": "array-replacement",
      "input": {
        "base": {
          "streaming": {
            "streams": [
              {
                "name": "shared",
                "sink": { "type": "kinesis", "streamName": "shared-stream" }
              }
            ]
          }
        },
        "component": {
          "streaming": {
            "streams": [
              {
                "name": "component",
                "sink": { "type": "kafka", "bootstrapServers": "localhost:9092", "topic": "component-topic" }
              }
            ]
          },
          "component": { "token": "file-replicator" }
        }
      },
      "expected": {
        "effective": {
          "streaming": {
            "streams": [
              {
                "name": "component",
                "sink": { "type": "kafka", "bootstrapServers": "localhost:9092", "topic": "component-topic" }
              }
            ]
          },
          "component": { "token": "file-replicator" }
        }
      }
    },
    {
      "name": "null-replacement",
      "input": {
        "base": { "tags": { "site": "dallas", "line": "north" } },
        "component": {
          "tags": null,
          "component": { "token": "opcua-adapter" }
        }
      },
      "expected": {
        "effective": {
          "tags": null,
          "component": { "token": "opcua-adapter" }
        }
      }
    },
    {
      "name": "type-conflict-component-wins",
      "input": {
        "base": { "logging": { "level": "INFO" } },
        "component": {
          "logging": "DEBUG",
          "component": { "token": "opcua-adapter" }
        }
      },
      "expected": {
        "effective": {
          "logging": "DEBUG",
          "component": { "token": "opcua-adapter" }
        },
        "warnings": [
          { "path": "$.logging", "code": "TYPE_CONFLICT_COMPONENT_WINS" }
        ]
      }
    },
    {
      "name": "control-fields-stripped",
      "input": {
        "base": {
          "extends": "ignored.json",
          "sharedConfig": true,
          "logging": { "level": "INFO" }
        },
        "component": {
          "extends": "shared.json",
          "sharedConfig": true,
          "component": { "token": "opcua-adapter" }
        }
      },
      "expected": {
        "effective": {
          "logging": { "level": "INFO" },
          "component": { "token": "opcua-adapter" }
        }
      }
    },
    {
      "name": "component-shared-config-false-skips-base",
      "input": {
        "base": { "logging": { "level": "INFO" } },
        "component": {
          "sharedConfig": false,
          "component": { "token": "opcua-adapter" }
        }
      },
      "expected": {
        "effective": {
          "component": { "token": "opcua-adapter" }
        }
      }
    },
    {
      "name": "cli-opt-out-skips-base",
      "input": {
        "options": { "noSharedConfig": true },
        "base": { "logging": { "level": "INFO" } },
        "component": {
          "component": { "token": "opcua-adapter" }
        }
      },
      "expected": {
        "effective": {
          "component": { "token": "opcua-adapter" }
        }
      }
    },
    {
      "name": "inherited-streaming-streams",
      "input": {
        "base": {
          "streaming": {
            "streams": [
              {
                "name": "telemetry",
                "sink": { "type": "kinesis", "streamName": "site-dallas-telemetry" },
                "buffer": { "type": "disk", "path": "/greengrass/v2/work/{ComponentName}/streams/telemetry" }
              }
            ]
          }
        },
        "component": {
          "component": { "token": "opcua-adapter" }
        }
      },
      "expected": {
        "effective": {
          "streaming": {
            "streams": [
              {
                "name": "telemetry",
                "sink": { "type": "kinesis", "streamName": "site-dallas-telemetry" },
                "buffer": { "type": "disk", "path": "/greengrass/v2/work/{ComponentName}/streams/telemetry" }
              }
            ]
          },
          "component": { "token": "opcua-adapter" }
        },
        "componentOwnsStreamRuntime": true
      }
    },
    {
      "name": "base-extends-rejected",
      "input": {
        "base": { "extends": "site.json" },
        "component": { "component": { "token": "opcua-adapter" } }
      },
      "expected": {
        "error": "N_LAYER_INHERITANCE_NOT_IMPLEMENTED"
      }
    }
  ]
}

