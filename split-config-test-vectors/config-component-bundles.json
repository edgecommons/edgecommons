{
  "description": "edgecommons CONFIG_COMPONENT layer bundle conformance vectors",
  "cases": [
    {
      "name": "legacy-component-only-reply",
      "input": {
        "body": {
          "logging": { "level": "INFO" },
          "component": { "token": "opcua-adapter" }
        }
      },
      "expected": {
        "base": null,
        "component": {
          "logging": { "level": "INFO" },
          "component": { "token": "opcua-adapter" }
        }
      }
    },
    {
      "name": "bundle-with-base-and-component",
      "input": {
        "body": {
          "base": {
            "hierarchy": { "levels": ["site", "device"] },
            "identity": { "site": "dallas" },
            "logging": { "level": "INFO" }
          },
          "component": {
            "component": { "token": "opcua-adapter" }
          }
        }
      },
      "expected": {
        "effective": {
          "hierarchy": { "levels": ["site", "device"] },
          "identity": { "site": "dallas" },
          "logging": { "level": "INFO" },
          "component": { "token": "opcua-adapter" }
        }
      }
    },
    {
      "name": "bundle-with-null-base",
      "input": {
        "body": {
          "base": null,
          "component": {
            "component": { "token": "modbus-adapter" }
          }
        }
      },
      "expected": {
        "effective": {
          "component": { "token": "modbus-adapter" }
        }
      }
    },
    {
      "name": "structured-error-reply",
      "input": {
        "body": {
          "ok": false,
          "error": {
            "code": "CONFIG_NOT_FOUND",
            "message": "No configuration catalog entry for component 'missing'"
          }
        }
      },
      "expected": {
        "error": "CONFIG_NOT_FOUND"
      }
    },
    {
      "name": "malformed-bundle-missing-component",
      "input": {
        "body": {
          "base": { "logging": { "level": "INFO" } }
        }
      },
      "expected": { "error": "CONFIG_COMPONENT_BUNDLE_INVALID" }
    },
    {
      "name": "malformed-bundle-non-object-base",
      "input": {
        "body": {
          "base": "bad",
          "component": { "component": { "token": "opcua-adapter" } }
        }
      },
      "expected": { "error": "CONFIG_COMPONENT_BUNDLE_INVALID" }
    },
    {
      "name": "push-bundle-reload",
      "input": {
        "push": {
          "base": { "logging": { "level": "WARN" } },
          "component": { "component": { "token": "opcua-adapter" } }
        }
      },
      "expected": {
        "effective": {
          "logging": { "level": "WARN" },
          "component": { "token": "opcua-adapter" }
        }
      }
    }
  ]
}

