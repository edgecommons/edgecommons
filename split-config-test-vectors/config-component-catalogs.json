{
  "description": "edgecommons ConfigComponent catalog server conformance vectors",
  "cases": [
    {
      "name": "valid-catalog-with-base-and-two-components",
      "input": {
        "catalog": {
          "schemaVersion": 1,
          "version": "v1",
          "provenance": { "source": "file", "uri": "/etc/edgecommons/catalog.json" },
          "base": { "logging": { "level": "INFO" } },
          "components": {
            "opcua-adapter": { "component": { "token": "opcua-adapter" } },
            "modbus-adapter": { "component": { "token": "modbus-adapter" } }
          }
        }
      },
      "expected": { "valid": true, "version": "v1", "componentCount": 2 }
    },
    {
      "name": "valid-catalog-with-no-base",
      "input": {
        "catalog": {
          "schemaVersion": 1,
          "version": "v2",
          "components": {
            "opcua-adapter": { "component": { "token": "opcua-adapter" } }
          }
        }
      },
      "expected": { "valid": true, "base": null }
    },
    {
      "name": "catalog-version-provenance-present",
      "input": {
        "catalog": {
          "schemaVersion": 1,
          "version": "git:8f2c9c7",
          "provenance": {
            "source": "git",
            "uri": "https://github.com/example/edge-configs.git",
            "revision": "8f2c9c7"
          },
          "components": {
            "opcua-adapter": { "component": { "token": "opcua-adapter" } }
          }
        }
      },
      "expected": { "valid": true, "version": "git:8f2c9c7", "provenanceSource": "git" }
    },
    {
      "name": "file-loaded-catalog-derives-version",
      "input": {
        "source": { "type": "file", "uri": "/etc/edgecommons/catalog.json", "contentHash": "sha256:abc123" },
        "catalog": {
          "schemaVersion": 1,
          "components": {
            "opcua-adapter": { "component": { "token": "opcua-adapter" } }
          }
        }
      },
      "expected": { "valid": true, "derivedVersionRequired": true }
    },
    {
      "name": "invalid-missing-components",
      "input": { "catalog": { "schemaVersion": 1, "version": "bad" } },
      "expected": { "error": "CATALOG_INVALID" }
    },
    {
      "name": "invalid-non-object-component-entry",
      "input": {
        "catalog": {
          "schemaVersion": 1,
          "version": "bad",
          "components": { "opcua-adapter": "bad" }
        }
      },
      "expected": { "error": "CATALOG_INVALID" }
    },
    {
      "name": "bad-request-missing-body-component",
      "input": { "requestBody": {} },
      "expected": {
        "reply": {
          "ok": false,
          "error": { "code": "BAD_REQUEST" }
        }
      }
    },
    {
      "name": "not-found-unknown-component-token",
      "input": {
        "catalog": {
          "schemaVersion": 1,
          "version": "v1",
          "components": {}
        },
        "requestBody": { "component": "opcua-adapter" }
      },
      "expected": {
        "reply": {
          "ok": false,
          "error": { "code": "CONFIG_NOT_FOUND" }
        }
      }
    },
    {
      "name": "catalog-reload-push-bundle-for-every-component",
      "input": {
        "oldCatalog": {
          "schemaVersion": 1,
          "version": "old",
          "components": {
            "opcua-adapter": { "component": { "token": "opcua-adapter" } }
          }
        },
        "newCatalog": {
          "schemaVersion": 1,
          "version": "new",
          "base": { "logging": { "level": "WARN" } },
          "components": {
            "opcua-adapter": { "component": { "token": "opcua-adapter" } },
            "modbus-adapter": { "component": { "token": "modbus-adapter" } }
          }
        }
      },
      "expected": {
        "pushTopics": [
          "ecv1/gw-01/opcua-adapter/main/cmd/set-config",
          "ecv1/gw-01/modbus-adapter/main/cmd/set-config"
        ],
        "pushedVersion": "new"
      }
    },
    {
      "name": "message-update-valid-full-replacement",
      "input": {
        "updateBody": {
          "version": "git:8f2c9c7",
          "catalog": {
            "schemaVersion": 1,
            "version": "git:8f2c9c7",
            "components": {
              "opcua-adapter": { "component": { "token": "opcua-adapter" } }
            }
          }
        }
      },
      "expected": {
        "ack": { "ok": true, "version": "git:8f2c9c7" },
        "promote": true,
        "persist": false,
        "provenanceSource": "message",
        "volatile": true
      }
    },
    {
      "name": "message-update-disabled-by-default-rejects-and-keeps-current",
      "input": {
        "activeVersion": "old",
        "updateBody": {
          "version": "new",
          "catalog": {
            "schemaVersion": 1,
            "version": "new",
            "components": {
              "opcua-adapter": { "component": { "token": "opcua-adapter" } }
            }
          }
        }
      },
      "expected": {
        "ack": { "ok": false, "error": { "code": "CATALOG_UPDATE_DISABLED" } },
        "activeVersion": "old",
        "push": false
      }
    },
    {
      "name": "message-update-invalid-catalog-rejects-and-keeps-current",
      "input": {
        "activeVersion": "old",
        "updateBody": {
          "version": "bad",
          "catalog": { "schemaVersion": 1 }
        }
      },
      "expected": {
        "ack": { "ok": false, "error": { "code": "CATALOG_INVALID" } },
        "activeVersion": "old",
        "push": false
      }
    },
    {
      "name": "read-only-source-accepts-enabled-volatile-message-update",
      "input": {
        "source": { "type": "git", "readOnly": true },
        "updateBody": {
          "version": "new",
          "catalog": {
            "schemaVersion": 1,
            "version": "new",
            "components": {
              "opcua-adapter": { "component": { "token": "opcua-adapter" } }
            }
          }
        }
      },
      "expected": {
        "ack": { "ok": true, "version": "new" },
        "promote": true,
        "persist": false
      }
    }
  ]
}
